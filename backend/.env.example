# ════════════════════════════════════════════════════════════════════════════
#  RAG Chatbot — Backend Environment Variables
#  Copy this file to .env and fill in the required values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                    # Your OpenAI API key
SECRET_KEY=change-me-use-openssl-rand-hex-32   # JWT signing secret

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="RAG Chatbot API"
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production                  # development | production

# ── OpenAI models ─────────────────────────────────────────────────────────────
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.2

# ── Storage paths ─────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
UPLOAD_DIR=./data/uploads

# ── Document processing ───────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=5

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── CORS (comma-separated list) ───────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Demo users: "username:password,username2:password2" ─────────────────────
# In production replace with proper DB + hashed passwords
DEMO_USERS=admin:admin123,user:user123

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440        # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=7
